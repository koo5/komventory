# Local compose overrides. Copy to `.env` (gitignored) and edit; `docker compose`
# reads `.env` automatically for ${VAR} substitution in compose.yml.
#
# Every value here has a working default in compose.yml — an empty .env (or no
# .env at all) runs a self-contained instance with all data under ./data. The
# settings below are for pointing the containers at your real host paths/keys.

# ---------------------------------------------------------------- content --

# Content language: drives the LLM system prompt + answers, the question-word
# heuristic, the Whisper transcription language, and the default TTS voice.
# Supported: en (default) | cs. The UI chrome stays English regardless.
KOMVENTORY_LANG=en

# Voice selection is a separate axis from language — uncomment to override the
# language's default Piper voice (e.g. a Czech jirka fine-tune):
#KOMVENTORY_TTS_VOICE=thomcles-medium

# Whisper model. Default large-v3 (multilingual, auto-downloads in CT2 form).
# Point this at an HF finetune for better per-language accuracy — but the
# container has no torch, so build its CT2 cache once on the host first:
#   scripts/warm-whisper-cache.fish
#KOMVENTORY_WHISPER_MODEL=mikr/whisper-large-v3-czech-cv13

# ------------------------------------------------------------------- Q&A --

# LLM for the "answer questions" feature (any LiteLLM model id).
#KOMVENTORY_QA_MODEL=gemini/gemini-2.5-flash

# Provider key for the model above. Simplest: set it here. Alternatively drop a
# file named after the env var into ./secrets/ (or KOMVENTORY_SECRETS_DIR).
#GEMINI_API_KEY=

# ----------------------------------------------------------------- host --

# UID:GID that should own files created in the bind mounts (run `id -u`:`id -g`).
#KOMVENTORY_UIDGID=1000:1000

# Host-specific bind mounts (external phone-sync folders, your own gitconfig, a
# peer log clone, an external secrets dir) are NOT set here — they live in
# compose.override.yml. Copy compose.override.yml.example to get started.
