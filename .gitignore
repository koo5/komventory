__pycache__/
*.pyc
.venv/
.uv/
.python-version

# Mutable state — personal data and host-specific symlinks live outside git.
# Track the layout via .gitkeep markers in dirs we own (not the symlinked ones).
data/*
!data/.gitkeep
!data/log/
data/log/*
!data/log/.gitkeep
!data/inbox/
data/inbox/*
!data/inbox/.gitkeep
!data/inbox/openclaw/
!data/inbox/imports/
data/inbox/openclaw/*
data/inbox/imports/*
!data/inbox/openclaw/.gitkeep
!data/inbox/imports/.gitkeep
.claude/
.dev_intention
