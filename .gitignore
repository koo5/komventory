__pycache__/
*.pyc
.venv/
.uv/
.python-version

# All runtime state — personal notes, log.md, media, model cache, and any
# host-specific clones/symlinks — lives under data/. None of it is git's
# business; we keep only an empty mount-point anchor so the bind mount resolves.
data/*
!data/.gitkeep

# Provider API keys (one file per key, read by qa.py). Never commit these.
secrets/*
!secrets/.gitkeep

.claude/
.dev_intention

# Local compose overrides — scalar settings (host UID, API keys, language, model).
# .env.example is the tracked template; copy it to .env (gitignored) and edit.
.env

# Host-specific bind mounts. compose.override.yml.example is the tracked template;
# copy it to compose.override.yml (gitignored) — docker auto-merges it.
compose.override.yml
secrets/